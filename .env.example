# ============================================================
# Voice to Claude — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ----------------------------------------------------------
# REQUIRED: Slack Bot Token (xoxb-...)
# Get from: api.slack.com/apps -> Your App -> OAuth & Permissions -> Bot User OAuth Token
# ----------------------------------------------------------
SLACK_BOT_TOKEN=

# ----------------------------------------------------------
# REQUIRED: Slack App-Level Token for Socket Mode (xapp-...)
# Get from: api.slack.com/apps -> Your App -> Basic Information -> App-Level Tokens
# Scope required: connections:write
# ----------------------------------------------------------
SLACK_APP_TOKEN=

# ----------------------------------------------------------
# REQUIRED: Slack channel ID where Claude listens
# Get it: right-click the channel name in Slack -> View channel details -> Channel ID at bottom
# ----------------------------------------------------------
CLAUDE_CHANNEL=

# ----------------------------------------------------------
# REQUIRED: Your Slack user ID (only this user can interact with the bridge)
# Get it: Slack -> click your name -> View profile -> More (...) -> Copy member ID
# ----------------------------------------------------------
ALLOWED_SLACK_USER=

# ----------------------------------------------------------
# REQUIRED: Default repo name for Claude sessions
# Must be a key in REPO_PATHS (or the full path if using single-repo mode)
# ----------------------------------------------------------
DEFAULT_REPO=my-project

# ----------------------------------------------------------
# OPTIONAL: JSON map of repo name -> absolute path on disk
# If omitted, bridge uses DEFAULT_REPO as both name and path (single-repo mode)
#
# Example (multi-repo):
#   REPO_PATHS={"my-project":"/home/user/my-project","api":"/home/user/api"}
#
# Example (single-repo, no REPO_PATHS needed):
#   DEFAULT_REPO=/home/user/my-project
# ----------------------------------------------------------
REPO_PATHS=

# ----------------------------------------------------------
# OPTIONAL: Custom system prompt for Claude sessions
# Defaults to a generic helpful assistant prompt.
# Use this to give Claude context about your codebase or workflows.
#
# Example:
#   CLAUDE_SYSTEM_PROMPT=You are a developer assistant for my TypeScript monorepo. Always follow the project conventions in CLAUDE.md.
# ----------------------------------------------------------
CLAUDE_SYSTEM_PROMPT=

# ----------------------------------------------------------
# OPTIONAL: Hook relay port (default: 3847)
# This is the localhost port where Claude Code sends hook events.
# Must match the port in your ~/.claude/settings.json hooks config.
# ----------------------------------------------------------
HOOK_RELAY_PORT=3847

# ----------------------------------------------------------
# OPTIONAL: State file path (default: sessions.json in current directory)
# Override to store session state in a specific location.
# ----------------------------------------------------------
# STATE_FILE=/path/to/sessions.json

# ----------------------------------------------------------
# OPTIONAL: Google Gemini API key (for voice message transcription)
# Required only if you want to send audio files/voice memos to the bridge.
# Get from: aistudio.google.com/app/apikey
# ----------------------------------------------------------
GEMINI_API_KEY=
